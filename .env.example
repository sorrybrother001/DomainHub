# App
FLASK_SECRET_KEY=please_change_me
FLASK_ENV=development
DATABASE_URL=sqlite:///data/dev.db

# Email (placeholders)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USER
MAIL_PASSWORD=YOUR_MAIL_PASS
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=no-reply@example.com

# Payments (placeholders)
STRIPE_API_KEY=YOUR_API_KEY
STRIPE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
PAYPAL_CLIENT_ID=YOUR_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_API_SECRET

# Wallet placeholders
WALLET_PLACEHOLDER_ADDRESS=YOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY
WALLET_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Domain providers (placeholders)
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
NAMECHEAP_API_KEY=YOUR_NAMECHEAP_API_KEY
SPACESHIP_API_KEY=YOUR_SPACESHIP_API_KEY

# Admin
ADMIN_EMAIL=admin@example.com